# ─── cloudflare-verified-ddns — Environment Configuration ───

# Copy to `.env` and set values:
#   cp .env.example .env
#
# Do not commit your real `.env`.

# ─── Cloudflare API ───

# API token with: Zone → DNS → Edit
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=""

# Cloudflare Zone ID
CLOUDFLARE_ZONE_ID=""

# ─── DNS Record ───

# Fully qualified DNS name (e.g., vpn.example.com)
CLOUDFLARE_DNS_NAME=""

# DNS record ID for the above record
CLOUDFLARE_DNS_RECORD_ID=""
